      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" vertex="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontFamily=IBM Plex Sans;fontColor=light-dark(#161616,#f4f4f4);" value="&lt;b&gt;codeanalyzer-java — Neo4j property-graph schema&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6f6f6f&quot;&gt;source: src/main/java/com/ibm/cldk/neo4j · contract = schema.neo4j.json · SCHEMA_VERSION 1.0.0 · emitted by --emit neo4j&lt;/font&gt;">
          <mxGeometry x="40" y="20" width="1100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" vertex="1" style="rounded=8;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingRight=10;spacingTop=8;spacingBottom=8;fontFamily=IBM Plex Sans;fontSize=12;fontColor=light-dark(#161616,#f4f4f4);fillColor=light-dark(#ffffff,#1a1a1a);strokeColor=light-dark(#8d8d8d,#6f6f6f);" value="&lt;b&gt;Legend&lt;/b&gt;&lt;hr&gt;→ relationship (type on the edge)&lt;br&gt;↺ self-loop = recursive (nesting / extends / calls)&lt;br&gt;&lt;br&gt;&lt;b&gt;Identity&lt;/b&gt;&lt;br&gt;Type &amp; Callable share the :Symbol merge label&lt;br&gt;(key = id). Type.id = FQN; Callable.id = FQN#signature.&lt;br&gt;&lt;br&gt;&lt;b&gt;Provenance&lt;/b&gt;&lt;br&gt;every unit-owned node carries _unit (= file_key) so&lt;br&gt;the Bolt writer can replace exactly one unit's subgraph.&lt;br&gt;&lt;br&gt;&lt;b&gt;Tiers&lt;/b&gt;&lt;br&gt;red = root · blue = file · teal = declarations&lt;br&gt;gray = leaf records · purple = shared (no _unit)">
          <mxGeometry x="40" y="90" width="360" height="320" as="geometry" />
        </mxCell>

        <mxCell id="app" parent="1" vertex="1" style="rounded=8;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingRight=10;spacingTop=8;spacingBottom=8;fontFamily=IBM Plex Sans;fontSize=12;fontColor=light-dark(#161616,#f4f4f4);fillColor=light-dark(#fff1f1,#4b1a1f);strokeColor=light-dark(#da1e28,#fa4d56);" value="&lt;b&gt;:Application&lt;/b&gt;  «root»&lt;hr&gt;name  (key)&lt;br&gt;schema_version">
          <mxGeometry x="640" y="100" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cu" parent="1" vertex="1" style="rounded=8;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingRight=10;spacingTop=8;spacingBottom=8;fontFamily=IBM Plex Sans;fontSize=12;fontColor=light-dark(#161616,#f4f4f4);fillColor=light-dark(#edf5ff,#1c2a3f);strokeColor=light-dark(#0f62fe,#4589ff);" value="&lt;b&gt;:CompilationUnit&lt;/b&gt;  «file»&lt;hr&gt;file_key  (key)&lt;br&gt;file_path · package_name&lt;br&gt;content_hash · comment_count&lt;br&gt;_unit">
          <mxGeometry x="620" y="260" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="type" parent="1" vertex="1" style="rounded=8;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingRight=10;spacingTop=8;spacingBottom=8;fontFamily=IBM Plex Sans;fontSize=12;fontColor=light-dark(#161616,#f4f4f4);fillColor=light-dark(#d9fbfb,#0c2b2b);strokeColor=light-dark(#007d79,#08bdba);" value="&lt;b&gt;:Type&lt;/b&gt; :Symbol  «recursive»&lt;hr&gt;id = fqn  (key)&lt;br&gt;name · fqn · kind (class/interface/&lt;br&gt;enum/annotation/record)&lt;br&gt;modifiers[] · annotations[]&lt;br&gt;extends_list[] · implements_list[]&lt;br&gt;nested_type_declarations[]&lt;br&gt;flags: is_interface, is_nested_type,&lt;br&gt;is_inner_class, is_local_class,&lt;br&gt;is_entrypoint_class (+:Entrypoint)&lt;br&gt;parent_type · docstring · _unit">
